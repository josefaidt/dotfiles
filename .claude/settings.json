{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",

      "Bash(gh pr view *)",
      "Bash(gh pr create *)",

      "Read(.config/**)"
    ],
    "ask": ["Bash(gh pr merge *)"],
    "deny": ["Read(*.env)", "Bash(rm *)", "Bash(curl *)"],
    "defaultMode": "default"
  },
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "neovim",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/subagent-stop-neovim.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
