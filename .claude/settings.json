{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(gh pr view *)",
      "Read(.config/**)",
      "Read(notes.md)",
      "Bash(nvim --version)",
      "Bash(nvim --headless *)"
    ],
    "ask": ["Bash(gh pr create *)", "Bash(git commit *)", "Bash(rm *)"],
    "deny": ["Read(*.env)", "Bash(curl *)"],
    "defaultMode": "default"
  },
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "neovim",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/subagent-stop-neovim.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
