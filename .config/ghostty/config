font-size = 14
font-family = "OperatorMono Nerd Font"
font-style = Book
font-family-italic = "OperatorMono Nerd Font"
font-style-italic = "Book Italic"
font-thicken = true
cursor-style = block
# Theme options (uncomment to switch):
#theme = Catppuccin Mocha
#theme = Everforest Dark Hard
theme = Mellow
macos-titlebar-style = "tabs"
# macos-titlebar-style = hidden
shell-integration-features = no-cursor
window-padding-x = 8
# shell-integration = fish

# Anthropic's recommendation for claude code
keybind = shift+enter=text:\n

# Create new splits
keybind = super+d=new_split:right
keybind = super+\=new_split:down

# Navigate splits (like tmux/zellij)
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

# Developer layout
keybind = cmd+e=new_split:left
keybind = chain=text:nvim .\n
keybind = chain=resize_split:left,400
keybind = chain=new_split:down
keybind = chain=resize_split:down,400
keybind = chain=goto_split:left

# Zoom split
keybind = ctrl+o=toggle_split_zoom

# Resize key table
keybind = resize/k=resize_split:up,10
keybind = resize/j=resize_split:down,10
keybind = resize/h=resize_split:left,10
keybind = resize/l=resize_split:right,10
keybind = resize/escape=deactivate_key_table
keybind = resize/catch_all=ignore

keybind = ctrl+a=activate_key_table:resize

# Quick terminal
keybind = global:ctrl+i=toggle_quick_terminal
quick-terminal-position = center
quick-terminal-size = 1200px,800px
quick-terminal-animation-duration = 0
